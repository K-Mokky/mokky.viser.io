{
  "name": "viser",
  "version": "0.1.0",
  "private": false,
  "description": "CLI-first personal AI assistant that talks to logged-in AI CLIs and can bridge Discord/Telegram messages.",
  "author": "KMokky",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/K-Mokky/mokky.viser.io.git"
  },
  "bugs": {
    "url": "https://github.com/K-Mokky/mokky.viser.io/issues"
  },
  "homepage": "https://github.com/K-Mokky/mokky.viser.io#readme",
  "type": "module",
  "bin": {
    "viser": "./src/index.ts"
  },
  "files": [
    ".env.example",
    "README.md",
    "SECURITY.md",
    "PRIVACY.md",
    "CONTRIBUTING.md",
    "assets",
    "config",
    "plugins",
    "skills",
    "src",
    "tools",
    "tsconfig.json"
  ],
  "scripts": {
    "viser": "node src/index.ts",
    "chat": "node src/index.ts chat",
    "ask": "node src/index.ts ask",
    "doctor": "node src/index.ts doctor",
    "audit": "node src/index.ts audit",
    "release:audit": "node src/index.ts audit",
    "release:evidence": "node src/index.ts release-evidence",
    "release:evidence:providers": "node src/index.ts release-evidence --live --probe-all-providers",
    "release:evidence:strict": "node src/index.ts release-evidence --strict --live --probe-all-providers",
    "env-check": "node src/index.ts env-check",
    "env-init": "node src/index.ts env-init",
    "telegram": "node src/index.ts telegram",
    "discord": "node src/index.ts discord",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "gateway": "node src/index.ts gateway --strict --live --probe-all-providers",
    "gateway:raw": "node src/index.ts gateway --unsafe-skip-gate",
    "scheduler": "node src/index.ts scheduler",
    "scheduler:raw": "node src/index.ts scheduler --unsafe-skip-gate",
    "jobs": "node src/index.ts jobs",
    "run-jobs": "node src/index.ts run-jobs",
    "run-jobs:raw": "node src/index.ts run-jobs --unsafe-skip-gate",
    "job-worker": "node src/index.ts job-worker",
    "job-worker:raw": "node src/index.ts job-worker --unsafe-skip-gate",
    "setup": "node src/index.ts setup",
    "service": "node src/index.ts service",
    "config-check": "node src/index.ts config-check",
    "state-check": "node src/index.ts state-check",
    "preflight": "node src/index.ts preflight",
    "preflight:providers": "node src/index.ts preflight --strict --live --probe-all-providers",
    "launch-status": "node src/index.ts launch-status",
    "readiness": "node src/index.ts readiness",
    "verify": "node src/index.ts verify",
    "verify:providers": "node src/index.ts verify --strict --live --probe-all-providers",
    "next-steps": "node src/index.ts next-steps",
    "gateway:check": "node src/index.ts gateway --dry-run --strict --live --probe-all-providers",
    "service-run": "node src/index.ts service-run --live --probe-all-providers",
    "smoke": "node src/index.ts smoke",
    "backup": "node src/index.ts backup",
    "dashboard": "node src/index.ts dashboard",
    "dashboard:check": "node src/index.ts dashboard-check --strict",
    "dashboard:web": "node src/index.ts web-dashboard",
    "mcp-server": "node src/index.ts mcp-server",
    "mcp-client-config": "node src/index.ts mcp-client-config"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "keywords": [
    "ai-assistant",
    "cli",
    "codex",
    "claude",
    "gemini",
    "discord",
    "telegram"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
