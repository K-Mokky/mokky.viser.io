# LLM providers are intentionally used through logged-in local CLIs, not model APIs.
VISER_PROVIDER=codex
VISER_CONFIG=./viser.config.json

# Optional: point Viser at a non-default env/config before config loading.
# VISER_ENV=./.env

# Messenger/action bridge credentials are for Discord/Telegram/Slack/Matrix/Signal/iMessage/WhatsApp/LINE/KakaoTalk/Google Chat/generic Webhook/Home Assistant/Teams/Mattermost/Synology Chat/Rocket.Chat/Feishu/DingTalk/WeCom/Zalo/IRC/Twitch/ntfy/Mastodon/Nextcloud Talk/Webex/Zulip/Email/GitHub/Todoist/Notion/Obsidian transport/action use only.
# They are not used to call GPT/Claude/Gemini model APIs.
# Keep real tokens in your private .env/shell, not in viser.config.json.
# For real token files, run: chmod 600 .env
# Required only if webDashboard.allowRemote=true or you want token auth on localhost.
VISER_DASHBOARD_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_USER_ID=
